@page "/"
@attribute [Authorize]
<h1>Projection</h1>
@if (materializedMoneyItems == null)
{
    <div class="loading-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading projections...</p>
    </div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-2 col-5">
            <span>To:</span><br />
            <RadzenDatePicker @bind-Value="FilterDateTo" DateFormat="dd/MM/yyyy" Change="@(args => Change(args, nameof(FilterDateTo)))" />
        </div>
        <div class="col-md-1 col-2">
            <label>Past</label><br>
            <RadzenSwitch @bind-Value="@ShowPastItems" Change="PastItems_Changed" />
        </div>
        <div class="col-md-1 col-3">
            <label>Zero</label><br>
            <RadzenSwitch @bind-Value="@ShowZero" Change="Zero_Changed" />
        </div>
        <div class="col-md-8 col-2">
            <br />
            <button class="btn-sm btn-success" @onclick="AddNew">
                <span class="oi oi-plus" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    @* Dashboard Summary Cards *@
    <div class="row mb-3 summary-cards">
        <div class="col-md-3 col-6 mb-2">
            <div class="summary-card summary-card-balance">
                <div class="summary-card-label">Current Balance</div>
                <div class="summary-card-value">@CurrentBalance.ToString("N2")</div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-2">
            <div class="summary-card summary-card-projected">
                <div class="summary-card-label">Next Period End</div>
                <div class="summary-card-value">@NextPeriodEndProjection.ToString("N2")</div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-2">
            <div class="summary-card summary-card-income">
                <div class="summary-card-label">Period Income</div>
                <div class="summary-card-value">+@PeriodIncome.ToString("N2")</div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-2">
            <div class="summary-card summary-card-expense">
                <div class="summary-card-label">Period Expenses</div>
                <div class="summary-card-value">@PeriodExpenses.ToString("N2")</div>
            </div>
        </div>
    </div>

    @* Balance Trend Mini-Chart *@
    @if (BalanceTrendData.Any())
    {
        <div class="balance-trend-container mb-3">
            <RadzenChart Style="height: 120px; width: 100%;">
                <RadzenAreaSeries Smooth="true" Data="@BalanceTrendData" CategoryProperty="Label" ValueProperty="Value"
                                  Stroke="rgba(96, 54, 142, 0.8)" Fill="rgba(96, 54, 142, 0.15)" StrokeWidth="2">
                    <RadzenMarkers Visible="false" />
                </RadzenAreaSeries>
                <RadzenCategoryAxis Visible="false" />
                <RadzenValueAxis Visible="false">
                    <RadzenGridLines Visible="false" />
                </RadzenValueAxis>
            </RadzenChart>
        </div>
    }

    @if (fixedMoneyItemsToVerify.Length > 0)
    {
        <div class="row mb-2">
            <div class="col">
                <div class="alert alert-warning d-flex align-items-center py-2 mb-0" role="alert">
                    <span class="oi oi-warning me-2" aria-hidden="true"></span>
                    <a href="fixed-items?toverify=1">@fixedMoneyItemsToVerify.Length items to review</a>
                </div>
            </div>
        </div>
    }
    <div class="table-responsive-sm">
        <table id="projections" class="table table-sm table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th></th>
                    <th>Date</th>
                    <th class="text-end">Amount</th>
                    <th></th>
                    <th class="text-end">Projection</th>
                    <th class="transaction-type-col"></th>
                    <th>Note</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in materializedMoneyItems)
                {
                    <tr class="@(item.EndPeriod ? "end-period" : "") @GetAmountRowClass(item) item-action" @onclick="@(() => item.IsRecurrent ? AdjustRecurrency(item) : AdjustFixedItem(item))">
                        <td class="text-center">
                            @if (item.Date <= DateTime.Now.Date)
                            {
                                <span class="oi oi-check done-item" aria-hidden="true"></span>
                            }
                        </td>
                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">@item.Amount.ToString("N2")</td>
                        <td class="text-center">
                            @{
                                var iconToUse = "";
                                var classToUse = "";
                                if (!item.EndPeriod)
                                {
                                    if (item.Amount > 0)
                                    {
                                        iconToUse = "arrow-thick-top";
                                        classToUse = "text-success";
                                    }
                                    else if (item.Amount < 0)
                                    {
                                        iconToUse = "arrow-thick-bottom";
                                        classToUse = "text-danger";
                                    }
                                    else
                                    {
                                        iconToUse = "ellipses";
                                        classToUse = "text-none";
                                    }
                                }
                                else
                                {
                                    if (item.Amount >= 0)
                                    {
                                        iconToUse = "circle-check";
                                        classToUse = "text-success";
                                    }
                                    else
                                    {
                                        iconToUse = "circle-x";
                                        classToUse = "text-danger";
                                    }
                                }
                            }
                            <span class="oi oi-@iconToUse @classToUse" aria-hidden="true" title="Fixed"></span>
                        </td>
                        @{
                            var projectionStyle = "text-end " + (item.Date <= DateTime.Now.Date ? " done-projection" : "");
                        }
                        <td class="@projectionStyle">
                            @item.Projection.ToString("N2")
                        </td>
                        <td class="transaction-type-col">
                            @if (!item.EndPeriod)
                            {
                                @if (item.Category?.ID == CurrentConfiguration.CashWithdrawalCategoryID)
                                {
                                    <span class="oi oi-browser" aria-hidden="true"></span>
                                }
                                else if (item.Cash)
                                {
                                    <span class="oi oi-euro" aria-hidden="true"></span>
                                }
                                else
                                {
                                    <span class="oi oi-credit-card" aria-hidden="true"></span>
                                }
                            }
                        </td>
                        <td class="ellipses">
                            @if (!item.EndPeriod && !string.IsNullOrEmpty(item.Category?.Icon))
                            {
                                <span class="category-icon" title="@item.Category?.Description">@item.Category?.Icon</span>
                            }
                            @item.Note
                        </td>
                        <td>
                            @if (!item.EndPeriod)
                            {
                                if (item.IsRecurrent)
                                {
                                    <span class="oi oi-pulse edit-adjustment" aria-hidden="true" title="Recurrent"></span>
                                }
                                else
                                {
                                    <span class="oi oi-pin edit-adjustment" aria-hidden="true" title="Fixed"></span>
                                }
                            }
                            else
                            {
                                if (item.ID == 0)
                                {
                                    <span class="oi oi-lock-locked text-success materialize-history" aria-hidden="true" title="Save materialized history" @onclick="() => SaveMaterializedHistory(item.Date)"></span>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
